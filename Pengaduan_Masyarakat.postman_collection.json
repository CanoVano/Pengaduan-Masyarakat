{
	"info": {
		"name": "Pengaduan Masyarakat API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api"
		},
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "admin_token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "AUTH",
			"item": [
				{
					"name": "1. Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/register",
							"host": ["{{base_url}}"],
							"path": ["register"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "2. Login (User)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "3. Login (Admin)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('admin_token', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "4. Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/logout",
							"host": ["{{base_url}}"],
							"path": ["logout"]
						}
					}
				}
			]
		},
		{
			"name": "REPORT USER",
			"item": [
				{
					"name": "5. Buat Laporan",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}"
								}
							]
						},
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "deskripsi",
									"value": "Jalan rusak di Jl. Sudirman",
									"type": "text"
								},
								{
									"key": "foto_before",
									"type": "file",
									"src": ""
								},
								{
									"key": "latitude",
									"value": "-6.2088",
									"type": "text"
								},
								{
									"key": "longitude",
									"value": "106.8456",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/reports",
							"host": ["{{base_url}}"],
							"path": ["reports"]
						}
					}
				},
				{
					"name": "6. Lihat Semua Laporan User",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/reports",
							"host": ["{{base_url}}"],
							"path": ["reports"]
						}
					}
				},
				{
					"name": "7. Detail Laporan User",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/reports/1",
							"host": ["{{base_url}}"],
							"path": ["reports", "1"]
						}
					}
				}
			]
		},
		{
			"name": "ADMIN",
			"item": [
				{
					"name": "8. Admin - Semua Laporan",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{admin_token}}"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/admin/reports",
							"host": ["{{base_url}}"],
							"path": ["admin", "reports"]
						}
					}
				},
				{
					"name": "9. Admin - Detail Laporan",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{admin_token}}"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/admin/reports/1",
							"host": ["{{base_url}}"],
							"path": ["admin", "reports", "1"]
						}
					}
				},
				{
					"name": "10. Admin - Update Status",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{admin_token}}"
								}
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"Diproses\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/admin/reports/1",
							"host": ["{{base_url}}"],
							"path": ["admin", "reports", "1"]
						}
					}
				},
				{
					"name": "11. Admin - Selesaikan Laporan",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{admin_token}}"
								}
							]
						},
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "foto_after",
									"type": "file",
									"src": ""
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/admin/reports/1/complete",
							"host": ["{{base_url}}"],
							"path": ["admin", "reports", "1", "complete"]
						}
					}
				}
			]
		},
		{
			"name": "NOTIFICATION",
			"item": [
				{
					"name": "12. Lihat Notifikasi",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/notifications",
							"host": ["{{base_url}}"],
							"path": ["notifications"]
						}
					}
				},
				{
					"name": "13. Tandai Notifikasi Dibaca",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/notifications/1/read",
							"host": ["{{base_url}}"],
							"path": ["notifications", "1", "read"]
						}
					}
				}
			]
		}
	]
}
